# Copy this file to `.env` and fill in real values.
# `.env` is gitignored (see .gitignore); `.env.example` is committed.

# -----------------------------------------------------------------------------
# Required: Nebius AI Studio API key
# -----------------------------------------------------------------------------
# Get yours at https://studio.nebius.com/
NEBIUS_API_KEY=nebius-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Optional: override the Nebius API base URL
# -----------------------------------------------------------------------------
# Default: https://api.studio.nebius.com/v1/
# NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/

# -----------------------------------------------------------------------------
# Optional: per-call token-usage logging to stderr
# -----------------------------------------------------------------------------
# Set to "1" / "true" / "yes" to enable. Logs one line per LLM call:
#   llm model=<m> prompt=<n> completion=<n> total=<n>
# No prompt content is ever logged.
# LOG_LLM_USAGE=0

# -----------------------------------------------------------------------------
# Optional: provider-specific HF mirror (rarely needed)
# -----------------------------------------------------------------------------
# Sentence-transformers downloads BAAI/bge-small-en-v1.5 from HuggingFace on
# first run. Set HF_HOME to control the cache location.
# HF_HOME=~/.cache/huggingface
